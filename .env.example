# Copy this to .env and fill in. .env is gitignored — never commit real keys.
# These are SEPARATE keys from the ORB bot — generate them under your second
# Alpaca paper account so the two bots don't interfere with each other.
# Paper dashboard: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here
ALPACA_PAPER=true
